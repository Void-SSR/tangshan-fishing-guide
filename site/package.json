{
  "name": "tangshan-fishing-guide-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "npm run build && python3 -m http.server 4321 -d dist",
    "serve": "python3 -m http.server 4321 -d dist",
    "safety:preflight": "node scripts/safety_preflight.mjs",
    "preview:diagnose": "node scripts/check-preview-env.mjs",
    "test:smoke": "npm run build && node tests/smoke-static.mjs",
    "test:browser": "npm run build && playwright test --config=tests/playwright.config.mjs"
  },
  "dependencies": {
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2"
  }
}
